function [M, tauHat, N] = SandC_m_comp(rx, gamma)

% modified from https://dspillustrations.com/pages/posts/misc/schmidlcox-synchronization-for-ofdm.html
% https://scispace.com/pdf/robust-frequency-and-timing-synchronization-for-ofdm-xyhk65f0x1.pdf

K = 64; % num FFT
L = floorDiv(K,2); % length of repeated part of preamble
oversample = 4; % oversampling factor

d_set = (L+K)*oversample;
N = L*oversample;

% holding tauHat value for valid frame detection
persistent tauHat_prev
if isempty(tauHat_prev)
    tauHat_prev = 1;
end

P = complex(zeros(d_set, 1));
R = zeros(length(P),1);
M = zeros(length(P),1);

for d = (1:d_set)
    timingSum = complex(0); % for finding P
    powerSum = 0; % for finding R
    for m = (1:N) % m = (1:L)
        index = d+N +m;  % index = d+L +m;
        sample = rx(index);
        
        % for finding P
        p1 = conj(rx(d +m));
        timingSum = timingSum +p1;
        % for finding R
        power = abs(sample)^2;
        powerSum = powerSum + power;
    end
    P(d) = timingSum;
    R(d) = powerSum;
    M(d) = abs(P(d))^2 / (R(d)^2 + 1e-12);

end


% FINDING TIMING FOR FFT ALIGNMENT
[Mmax, i] = max(M);

if Mmax > gamma
    tauHat = i -1; % -1 to change from 1-based counting to 0-based counting
    tauHat_prev = tauHat;
else
    tauHat = tauHat_prev; % new tauHat is previous valid tauHat
end

end
